# Postgres connection string
DATABASE_URL="postgresql://user:password@localhost:5432/condenser_experimental"

# Anthropic API key for voice extraction + vision
ANTHROPIC_API_KEY="sk-ant-..."

# Required for auth. Generate with: openssl rand -hex 32
# Rotating this invalidates every logged-in session.
JWT_SECRET=""

# Server port (Railway sets this automatically)
PORT=3001

# Allowed origin for CORS. Use the frontend URL in production.
CORS_ORIGIN="http://localhost:5173"
